{
  "name": "nodistraction",
  "private": false,
  "version": "0.0.0",
  "type": "module",
  "main": "main.js",
  "description": "A distraction-free, customizable macOS menu bar Pomodoro focus timer.",
  "author": "Mahtab Tanim",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently \"npm run dev:vite\" \"npm run dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "electron .",
    "build": "vite build",
    "package": "npm run build && electron-builder --publish never"
  },
  "dependencies": {
    "lucide-react": "^1.23.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^9.2.3",
    "electron": "^41.7.1",
    "electron-builder": "^26.15.3",
    "vite": "^8.1.1"
  },
  "build": {
    "appId": "com.nodistraction.pomodoro",
    "productName": "NoDistraction",
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg"
      ],
      "icon": "icons/icons8-year-of-tiger-512.png"
    },
    "files": [
      "dist/**/*",
      "main.js",
      "preload.cjs",
      "trayIcon.png",
      "trayIcon@2x.png",
      "package.json"
    ],
    "directories": {
      "output": "release"
    }
  }
}
